    "build": "tsc -p tsconfig.json && node -e \"require('fs').cpSync('recipes', 'dist/recipes', { recursive: true })\"",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
