{
  "name": "@beatzball/litro-router",
  "version": "0.1.1",
  "type": "module",
  "types": "./dist/index.d.ts",
  "description": "Zero-dependency URLPattern client-side router for web components",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/beatzball/litro.git",
    "directory": "packages/litro-router"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "router",
    "web-components",
    "url-pattern",
    "lit",
    "client-side-routing"
  ],
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {},
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^2.1.8",
    "jsdom": "^25.0.0"
  }
