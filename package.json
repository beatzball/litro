{
  "name": "litro-workspace",
  "private": true,
  "scripts": {
    "clean": "pnpm dlx rimraf node_modules \"packages/*/node_modules\" \"packages/*/dist\" \"playground*/node_modules\" \"playground*/dist\" \"docs/node_modules\" \"docs/dist\" .output .nitro \"playground*/server/stubs\" \"playground*/routes.generated.ts\" \"docs/server/stubs\" \"docs/routes.generated.ts\" test-results playwright-report \"e2e/test-results\" \"**/*.tsbuildinfo\"",
    "setup": "pnpm install && pnpm --filter @beatzball/litro-router build && pnpm --filter @beatzball/litro build && pnpm install",
    "dev": "pnpm --filter playground dev",
    "build": "pnpm --filter playground build",
    "preview": "pnpm --filter playground preview",
    "dev:11ty": "pnpm --filter playground-11ty dev",
    "build:11ty": "pnpm --filter playground-11ty build",
    "preview:11ty": "pnpm --filter playground-11ty preview",
    "prepare:11ty": "pnpm --filter @beatzball/litro-router build && pnpm --filter @beatzball/litro build",
    "dev:starlight": "pnpm --filter playground-starlight dev",
    "build:starlight": "pnpm --filter playground-starlight build",
    "preview:starlight": "pnpm --filter playground-starlight preview",
    "prepare:starlight": "pnpm --filter @beatzball/litro-router build && pnpm --filter @beatzball/litro build",
    "dev:docs": "pnpm --filter @beatzball/litro-docs dev",
    "build:docs": "pnpm --filter @beatzball/litro-docs build",
    "preview:docs": "pnpm --filter @beatzball/litro-docs preview",
    "prepare:docs": "pnpm --filter @beatzball/litro-router build && pnpm --filter @beatzball/litro build",
    "test": "pnpm --filter @beatzball/litro test",
    "test:docs": "pnpm --filter @beatzball/litro-docs test",
    "test:e2e": "playwright test",
    "test:e2e:preview": "playwright test --config playwright.preview.config.ts",
    "lint": "tsc --noEmit -p packages/framework/tsconfig.json",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm -r --filter \"./packages/*\" build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.12",
    "@playwright/test": "^1.48.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "pnpm": {
    "overrides": {
      "serialize-javascript": ">=7.0.3",
      "tar": ">=7.5.11"
    }
  }
}
