{
  "name": "litro",
  "version": "0.0.1",
  "description": "Litro — fullstack Lit framework powered by Nitro",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/beatzball/litro.git",
    "directory": "packages/framework"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./cli": {
      "source": "./src/cli/index.ts",
      "import": "./dist/cli/index.js",
      "types": "./dist/cli/index.d.ts"
    },
    "./vite": {
      "source": "./src/vite/index.ts",
      "import": "./dist/vite/index.js",
      "types": "./dist/vite/index.d.ts"
    },
    "./runtime": {
      "source": "./src/runtime/index.ts",
      "import": "./dist/runtime/index.js",
      "types": "./dist/runtime/index.d.ts"
    },
    "./runtime/*.js": {
      "source": "./src/runtime/*.ts",
      "import": "./dist/runtime/*.js",
      "types": "./dist/runtime/*.d.ts"
    },
    "./plugins": {
      "source": "./src/plugins/pages.ts",
      "import": "./dist/plugins/pages.js",
      "types": "./dist/plugins/pages.d.ts"
    },
    "./plugins/ssg": {
      "source": "./src/plugins/ssg.ts",
      "import": "./dist/plugins/ssg.js",
      "types": "./dist/plugins/ssg.d.ts"
    },
    "./config": {
      "source": "./src/config/presets.ts",
      "import": "./dist/config/presets.js",
      "types": "./dist/config/presets.d.ts"
    },
    "./types": {
      "source": "./src/types/route.ts",
      "import": "./dist/types/route.js",
      "types": "./dist/types/route.d.ts"
    },
    "./content": {
      "source": "./src/content/index.ts",
      "import": "./dist/content/index.js",
      "types": "./dist/content/index.d.ts"
    },
    "./content/plugin": {
      "source": "./src/content/plugin.ts",
      "import": "./dist/content/plugin.js",
      "types": "./dist/content/plugin.d.ts"
    },
    "./content/env": {
      "types": "./src/content/env.d.ts"
    }
  },
  "bin": {
    "litro": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:cli": "tsc -p tsconfig.json --outDir dist",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "sideEffects": [
    "./src/runtime/LitroOutlet.ts",
    "./src/runtime/LitroLink.ts",
    "./dist/runtime/LitroOutlet.js",
    "./dist/runtime/LitroLink.js"
  ],
  "dependencies": {
    "litro-router": "workspace:*",
    "execa": "^8.0.1",
    "nitropack": "^2.13.1",
    "h3": "^1.13.0",
    "vite": "^5.4.11",
    "lit": "^3.2.1",
    "@lit-labs/ssr": "^3.3.0",
    "@lit-labs/ssr-client": "^1.1.7",
    "pathe": "^1.1.2",
    "fast-glob": "^3.3.3",
    "jiti": "^2.0.0",
    "gray-matter": "^4.0.3",
    "unified": "^11.0.5",
    "remark-parse": "^11.0.0",
    "remark-gfm": "^4.0.0",
    "remark-rehype": "^11.1.1",
    "rehype-stringify": "^10.0.1"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^2.1.8",
    "jsdom": "^25.0.0"
  },
  "peerDependencies": {
    "typescript": "^5.x"
  }
}
